    "post",
    "generator",
    "bluesky",
    "linkedin",
    "cli"
  ],
  "homepage": "https://github.com/jeromeetienne/aipostgen#readme",
  "bugs": {
    "url": "https://github.com/jeromeetienne/aipostgen/issues"
  },
